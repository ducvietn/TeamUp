# =====================================================
# TeamUp Environment Configuration
# =====================================================

NODE_ENV=development
PORT=5000

# =====================================================
# DATABASE - MongoDB Atlas (Cloud)
# =====================================================
# Get your connection string from: https://www.mongodb.com/atlas
# 1. Create cluster -> Security -> Database Access -> Add User
# 2. Network Access -> Allow Access from Anywhere
# 3. Connect -> Connect your application -> Copy connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/teamup?retryWrites=true&w=majority

# =====================================================
# CLOUDINARY (Cloud File Storage)
# =====================================================
# Sign up at: https://cloudinary.com
# Free tier: 25GB storage, 25GB bandwidth/month
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =====================================================
# JWT AUTHENTICATION
# =====================================================
JWT_SECRET=teamup_jwt_secret_key_2024_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# =====================================================
# CORS & CLIENT
# =====================================================
CLIENT_URL=http://localhost:3000

# =====================================================
# FILE UPLOAD
# =====================================================
MAX_FILE_SIZE=10485760
